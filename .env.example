# =============================================================================
# Sibylla — Variables de entorno (PLANTILLA)
# -----------------------------------------------------------------------------
# 1) Copia este archivo a ".env"      ->  cp .env.example .env   (o copia manual)
# 2) Rellena los valores reales en ".env"
# 3) NUNCA subas ".env" a git ni pegues estas claves en ningún chat.
#
# Nota: la MAYORÍA de fuentes del registro (RSS + APIs abiertas: arXiv,
# Europe PMC, GDELT, Google News, Hacker News, Crossref, bioRxiv, Mastodon
# público...) NO requieren clave. Aquí solo van las que sí.
# =============================================================================

# --- X (Twitter) API v2 — Pay Per Use --------------------------------------
# console.x.com -> app de "Development" -> pestaña "Keys and tokens".
# Para LECTURA (Recent Search, últimos 7 días) basta el Bearer Token (app-only).
X_BEARER_TOKEN=

# Opcionales, solo si luego hace falta contexto de usuario (OAuth):
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# (El tope de gasto mensual vive en config/sources.yaml -> x_twitter.monthly_read_budget)

# --- LLM para redactar el resumen (proveedor a elección; OPCIONAL) ---------
# Conecta la API que quieras. Si lo dejas vacío, Sibylla genera la lista
# determinista (sin IA). Ejemplos por proveedor:
#   anthropic         -> LLM_MODEL=claude-opus-4-8        (Claude)
#   openai            -> LLM_MODEL=gpt-4o-mini            (OpenAI)
#   openrouter        -> LLM_MODEL=anthropic/claude-3.5   (multi-modelo)
#   openai_compatible -> define LLM_BASE_URL (Groq, Together, LM Studio, vLLM...)
#   ollama            -> LLM_MODEL=llama3.1  (local, sin API key)
#
# Ejemplo DeepSeek (OpenAI-compatible):
#   LLM_PROVIDER=openai_compatible
#   LLM_MODEL=deepseek-v4-flash          (o deepseek-v4-pro)
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_API_KEY=sk-...                   (tu clave de platform.deepseek.com)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# --- Idioma de la web y el resumen (opcional) -------------------------------
# Valores: es, en, it, pt. Si no se define, se usa default_user_language
# de config/sources.yaml; si tampoco, el fallback es 'es'.
SIBYLLA_LANG=

# --- URL pública del sitio (usada para meta tags SEO, sitemap, etc.) ---------
# Sin barra final. Si no se define, usa el fallback.
SIBYLLA_SITE_URL=https://sibylla.cl

# --- Verificación de Google Search Console (opcional) -----------------------
# Solo el VALOR del token que da Google en "Etiqueta HTML" (el content="...",
# no la etiqueta completa). Se hornea como <meta name="google-site-verification">
# en todas las páginas, así sobrevive a cada regeneración. Déjalo vacío si
# verificas el dominio por DNS (método recomendado para propiedad de Dominio).
SIBYLLA_GOOGLE_VERIFICATION=

# --- YouTube Data API v3 (opcional, recomendado para Divulgación) ----------
# La web puede caer al feed Atom si no hay clave, pero YouTube throttlea feeds
# desde IPs de CI. La herramienta admin también la usa para resolver @handles.
YOUTUBE_API_KEY=

# --- Herramienta admin local (dashboard de métricas + gestión, NO se publica) -
# `python -m sibylla.cli --dashboard` arranca un servidor local en
# http://127.0.0.1:8765 con dos secciones: /metricas (historial de producción)
# y /divulgacion (gestión de canales de YouTube). La sección /metricas descarga
# runs.json del host por SSH al arrancar (best-effort: si falla, sigue la
# administración); usa las MISMAS credenciales del deploy:
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22
# Ruta (relativa al home SSH, fuera del web root) donde el host guarda runs.json.
DEPLOY_DATA_PATH=.sibylla
# Ruta a tu clave privada SSH. Si la omites, se usa tu config SSH / el agente.
DEPLOY_KEY_FILE=

# --- PubMed / NCBI E-utilities (opcional, recomendado) ---------------------
# Funciona sin clave (3 req/s). Con clave gratuita sube a 10 req/s.
NCBI_API_KEY=

# --- Semantic Scholar (opcional, sube el rate limit) -----------------------
SEMANTIC_SCHOLAR_API_KEY=

# --- The Guardian Open Platform (clave gratuita, uso no comercial) ----------
GUARDIAN_API_KEY=

# --- Bluesky / AT Protocol (gratis; búsqueda requiere app password) --------
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# --- Firebase service account (fase social: conteos en el build) -----------
# JSON de la key del service account (proyecto sibylla-a81d2, rol mínimo
# roles/datastore.viewer) para leer agregados/conteos por REST con token OAuth.
# Solo se necesita para que el build siga horneando los conteos tras activar el
# Enforce de App Check; sin él, el build cae al REST anónimo y el sitio sale sin
# números. En CI va como secret SIBYLLA_FIREBASE_SA_JSON; localmente puedes
# pegar aquí el JSON inline o usar GOOGLE_APPLICATION_CREDENTIALS con la ruta al
# archivo. NUNCA subas el .env con este valor (el repo es público).
SIBYLLA_FIREBASE_SA_JSON=
# Alternativa: ruta a un archivo de credenciales (google-auth también la lee).
GOOGLE_APPLICATION_CREDENTIALS=

{% extends "admin_base.html.j2" %}
{#
  Sibylla — sección /divulgación de la herramienta admin.
  Gestión de canales de YouTube: lista los existentes y permite alta/baja.
  Los cambios solo tocan config/sources.yaml y sibylla/pipeline.py; el banner
  git (admin_base) avisa de cambios pendientes de commit.
#}
{% block titulo %}Sibylla · Divulgación{% endblock %}

{% block styles %}
  .subhero{ padding:32px 0 8px; }
  .subhero h1{ font-family:'Cinzel',serif; font-weight:500;
    font-size:clamp(1.4rem,2.6vw,1.9rem); margin:0 0 6px; color:var(--marfil);
    letter-spacing:.14em; }
  .subhero p{ font-family:'Cormorant Garamond',serif; font-style:italic;
    color:var(--marfil-2); margin:0; font-size:1rem; }
  .subhero .total{ color:var(--oro-claro); font-variant-numeric:tabular-nums; }

  /* Tabla de canales */
  .tabla-wrap{ overflow-x:auto; margin:24px 0 36px;
    background:var(--panel); border:1px solid var(--panel-borde);
    border-radius:var(--radio); }
  table.canales{ width:100%; border-collapse:collapse; font-size:.84rem; }
  table.canales thead th{ text-align:left; font-weight:500; font-size:.72rem;
    letter-spacing:.1em; text-transform:uppercase; color:var(--tenue);
    padding:12px 14px; border-bottom:1px solid rgba(217,184,95,.22);
    background:rgba(13,19,34,.5); white-space:nowrap; }
  table.canales tbody td{ padding:11px 14px; border-bottom:1px solid rgba(217,184,95,.06);
    color:var(--marfil-2); vertical-align:top; }
  table.canales tbody tr:last-child td{ border-bottom:0; }
  table.canales tbody tr:hover td{ background:rgba(217,184,95,.04); }
  td.nombre{ color:var(--marfil); font-weight:500; }
  td.nombre a{ color:inherit; text-decoration:none; }
  td.nombre a:hover{ color:var(--oro-claro); text-decoration:underline; }
  td.handle, td.channel_id{ font-family:'Inter',sans-serif; font-size:.78rem;
    color:var(--tenue); font-variant-numeric:tabular-nums; white-space:nowrap; }
  td.status{ font-size:.74rem; color:var(--tier3); white-space:nowrap; }
  td.notas{ font-size:.76rem; color:var(--tenue); font-style:italic;
    max-width:280px; }
  td.acciones{ text-align:right; white-space:nowrap; }

  .btn-quitar{ background:rgba(224,96,96,.08); border:1px solid rgba(224,96,96,.3);
    color:#F2B0B0; padding:5px 12px; border-radius:8px; cursor:pointer;
    font-family:'Inter',sans-serif; font-size:.74rem; letter-spacing:.04em;
    transition:.18s; }
  .btn-quitar:hover{ background:rgba(224,96,96,.18); border-color:rgba(224,96,96,.5); }

  /* Formulario de alta */
  .alta-card{ background:var(--panel); border:1px solid var(--panel-borde);
    border-radius:var(--radio); padding:24px 26px; margin:8px 0 32px;
    backdrop-filter:blur(6px); }
  .alta-card h2{ font-family:'Cinzel',serif; font-weight:500; letter-spacing:.12em;
    font-size:1rem; color:var(--marfil); margin:0 0 6px; }
  .alta-card p.alta-help{ font-family:'Cormorant Garamond',serif; font-style:italic;
    color:var(--marfil-2); margin:0 0 18px; font-size:.92rem; }
  .alta-form{ display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; }
  .alta-form .campo{ display:flex; flex-direction:column; gap:5px; }
  .alta-form .campo.entrada{ flex:2; min-width:240px; }
  .alta-form .campo.nombre{ flex:1; min-width:180px; }
  .alta-form label{ font-size:.7rem; letter-spacing:.1em; text-transform:uppercase;
    color:var(--tenue); }
  .alta-form input[type=text]{ background:rgba(8,11,20,.6);
    border:1px solid var(--panel-borde); border-radius:8px;
    color:var(--marfil); padding:10px 12px; font-family:'Inter',sans-serif;
    font-size:.86rem; transition:border-color .2s; }
  .alta-form input[type=text]:focus{ outline:none; border-color:var(--oro); }
  .btn-alta{ background:linear-gradient(180deg,#F2DD93,#D9B85F);
    border:1px solid var(--bronce); color:#080B14; padding:11px 22px;
    border-radius:8px; cursor:pointer; font-family:'Inter',sans-serif;
    font-weight:500; font-size:.82rem; letter-spacing:.06em;
    transition:.2s; }
  .btn-alta:hover{ filter:brightness(1.08); transform:translateY(-1px); }

  /* Aviso de sin canales */
  .sin-canales{ text-align:center; padding:40px 0; color:var(--tenue); }
  .sin-canales p{ font-family:'Cormorant Garamond',serif; font-style:italic;
    font-size:1.05rem; }

  @media (max-width:680px){
    .alta-form{ flex-direction:column; align-items:stretch; }
    .alta-form .btn-alta{ width:100%; }
    td.notas{ display:none; }
    td.channel_id{ display:none; }
  }
{% endblock %}

{% block content %}
<section class="subhero">
  <h1>Divulgación</h1>
  <p>Canales de YouTube curados — <span class="total">{{ total }}</span> en producción</p>
</section>

<!-- ---- Alta de canal ---- -->
<form class="alta-form-wrap" method="post" action="/api/canales/agregar">
  <input type="hidden" name="csrf" value="{{ csrf }}">
  <div class="alta-card">
    <h2>Añadir canal</h2>
    <p class="alta-help">
      Pega la URL del canal, su <code>@handle</code> o el <code>UC…</code> directo.
      Con <code>YOUTUBE_API_KEY</code> se resuelve vía la API oficial; sin clave, por scraping.
      Siempre se verifica que el canal tenga videos antes de guardarlo.
    </p>
    <div class="alta-form">
      <div class="campo entrada">
        <label for="entrada">URL / @handle / UC…</label>
        <input type="text" id="entrada" name="entrada" required
               placeholder="https://www.youtube.com/@canal  ·  @canal  ·  UCxxxxxxxxxxxxxxxxxxxxxx">
      </div>
      <div class="campo nombre">
        <label for="nombre">Nombre (opcional)</label>
        <input type="text" id="nombre" name="nombre"
               placeholder="Se usa el del canal si lo dejas vacío">
      </div>
      <button type="submit" class="btn-alta">Añadir</button>
    </div>
  </div>
</form>

<!-- ---- Tabla de canales existentes ---- -->
{% if canales %}
<div class="tabla-wrap">
  <table class="canales">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Handle</th>
        <th>Channel ID</th>
        <th>Estado</th>
        <th>Notas</th>
        <th class="acciones">Acción</th>
      </tr>
    </thead>
    <tbody>
      {% for c in canales %}
      <tr>
        <td class="nombre">
          {% if c.url %}<a href="{{ c.url }}" target="_blank" rel="noopener">{{ c.name }}</a>{% else %}{{ c.name }}{% endif %}
        </td>
        <td class="handle">{{ c.handle }}</td>
        <td class="channel_id">{{ c.channel_id }}</td>
        <td class="status">{{ c.status }}</td>
        <td class="notas">{{ c.notes }}</td>
        <td class="acciones">
          <form method="post" action="/api/canales/quitar"
                onsubmit="return confirm('¿Quitar el canal \'{{ c.name }}\' ({{ c.id }}) de la sección Divulgación? El cambio quedará pendiente de commit.');"
                style="display:inline;">
            <input type="hidden" name="csrf" value="{{ csrf }}">
            <input type="hidden" name="canal_id" value="{{ c.id }}">
            <button type="submit" class="btn-quitar">Quitar</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<div class="sin-canales">
  <p>No hay canales en la sección Divulgación.</p>
  <p>Usa el formulario de arriba para añadir el primero.</p>
</div>
{% endif %}
{% endblock %}

<!DOCTYPE html>
{#
  Sibylla — Plantilla de la portada (FUENTE DE VERDAD del diseño)
  --------------------------------------------------------------
  Para cambiar la estética, edita ESTE archivo. NO edites web/index.html:
  es la SALIDA generada por sibylla/web.py y se sobrescribe en cada corrida.

  Concepto: "Lo que está sucediendo." — Sibylla, sibila/reportera, lee el
  presente. Acento oro/mármol. El avatar vive en el "portal" (.portal .lienzo).

  Variables que inyecta web.py:
    lang        -> código de idioma (siempre "es": sitio monolingüe)
    generado    -> "21 jun 2026, 06:54 UTC"
    hero_timestamp -> "Última lectura · 21 jun 2026…" (ya formateado)
    total       -> nº de señales analizadas (int)
    n_fuentes   -> nº de fuentes distintas (int)
    observa     -> texto del apunte "Sibylla observa"
    t           -> dict con las traducciones de la sección "web" del locale es
    grupos      -> [{id, label, cards:[{url,title,source_name,date,
                    seal_roman,seal_class,seal_color,snippet,image,
                    resumen,has_resumen,related,...}]}]
    sibylla_cards-> lo mismo, para "SIBYLLA" (publicaciones propias; puede
                    venir vacío y la sección no se renderiza)
    social_cards-> lo mismo, para "Voces de la red"
#}
{% macro busto() -%}
<span class="busto" aria-hidden="true"></span>
{%- endmacro %}
{% macro apunte(quien, texto, clase='') -%}
<div class="apunte{% if clase %} {{ clase }}{% endif %}">
  {{ busto() }}
  <div class="dice">
    <span class="quien">{{ quien }}</span>
    <p>«{{ texto }}»</p>
  </div>
</div>
{%- endmacro %}
{# Controles de sección: subir / bajar / quitar. La lógica vive en el <script>
   del pie (orden y visibilidad persisten en localStorage, todo client-side). #}
{% macro sec_ctrl() -%}
<span class="sec-ctrl">
  <button type="button" class="sec-btn sec-up" aria-label="{{ t.sec_up }}" title="{{ t.sec_up }}"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 10l4-4 4 4"/></svg></button>
  <button type="button" class="sec-btn sec-down" aria-label="{{ t.sec_down }}" title="{{ t.sec_down }}"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg></button>
  <button type="button" class="sec-btn sec-del" aria-label="{{ t.sec_remove }}" title="{{ t.sec_remove }}"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4.5 4.5l7 7M11.5 4.5l-7 7"/></svg></button>
</span>
{%- endmacro %}
{# Sin c.url (p. ej. publicaciones propias sin enlace externo) el <a> se
   renderiza sin href: HTML válido, sin semántica de enlace, y no aparece el
   botón "Original". #}
{% macro tarjeta(c, also_in='') -%}
<article id="{{ c.id }}" class="carta" style="--sello:{{ c.seal_color }};">
  {% if c.image %}<a class="carta-img"{% if c.url %} href="{{ c.url }}"{% endif %} aria-label="{{ c.title|e }}"{% if c.is_video and c.video_id %} data-video-id="{{ c.video_id }}"{% endif %}><img src="{{ c.image }}" alt="" loading="lazy" referrerpolicy="no-referrer" onerror="this.parentNode.classList.add('ph');this.remove();">{% if c.is_video %}<span class="play" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span>{% endif %}</a>{% else %}<a class="carta-img ph"{% if c.url %} href="{{ c.url }}"{% endif %} aria-label="{{ c.title|e }}"{% if c.is_video and c.video_id %} data-video-id="{{ c.video_id }}"{% endif %}>{% if c.is_video %}<span class="play" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span>{% endif %}</a>{% endif %}
  <h4>
    {% if c.network %}<span class="pill">{{ t['net_' + c.network] if not c.is_house else t.social_house_badge }}</span>{% endif %}
    <a{% if c.url %} href="{{ c.url }}"{% endif %}>{{ c.title }}</a>
  </h4>
  <div class="fuente">{% if c.is_video %}<span class="sello sello-video" title="{{ t.video_label }}">▶</span>{% else %}<span class="sello {{ c.seal_class }}">{{ c.seal_roman }}</span>{% endif %} {{ c.source_name }} <span class="sep">·</span> {{ c.date }}</div>
  {% if c.snippet %}<p class="resumen">{{ c.snippet }}</p>{% endif %}
  {% if c.related %}<p class="tambien">{{ also_in }}: {% for r in c.related %}<a href="{{ r.url }}">{{ r.source_name }}</a>{% if not loop.last %} <span class="sep">·</span> {% endif %}{% endfor %}{% if c.related_extra %} <span class="sep">·</span> +{{ c.related_extra }}{% endif %}</p>{% endif %}
  <div class="carta-acciones">
    {% if c.has_resumen %}<button type="button" class="btn-mini btn-resumen" aria-expanded="false">{{ t.btn_resumen }}</button>{% endif %}
    {% if c.url %}<a class="btn-mini btn-original" href="{{ c.url }}" target="_blank" rel="noopener">{{ t.btn_original }}</a>{% endif %}
    <span class="soc-grupo" data-card="{{ c.id }}">
      <button type="button" class="sec-btn soc-btn soc-like is-locked" data-vote="1" aria-pressed="false" aria-label="{{ t.social_like }}" title="{{ t.social_gate_hint }}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/></svg><span class="soc-num" data-num="like"></span></button><button type="button" class="sec-btn soc-btn soc-dislike is-locked" data-vote="-1" aria-pressed="false" aria-label="{{ t.social_dislike }}" title="{{ t.social_gate_hint }}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22a3.13 3.13 0 0 1-3-3.88Z"/></svg><span class="soc-num" data-num="dislike"></span></button><button type="button" class="sec-btn soc-btn soc-com" aria-expanded="false" aria-label="{{ t.social_comments }}" title="{{ t.social_comments }}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></button>
    </span>
  </div>
  {% if c.has_resumen %}<div class="resumen-panel" hidden>{{ c.resumen }}</div>{% endif %}
</article>
{%- endmacro %}
<!-- ARCHIVO GENERADO por sibylla/web.py — NO editar a mano. El diseño vive en sibylla/templates/index.html.j2 -->

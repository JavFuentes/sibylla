<!DOCTYPE html>
{#
  Sibylla — Dashboard de métricas
  Muestra: historial de regeneraciones, consumo de tokens, costo estimado.
#}
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sibylla · Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<meta name="theme-color" content="#080B14">
<style>
  :root{
    --obsidiana:#080B14; --noche:#0D1322; --panel:rgba(20,27,46,.55);
    --panel-borde:rgba(217,184,95,.22); --marfil:#ECE4D2; --marfil-2:#C3BCA9;
    --tenue:#8E8979; --oro:#D9B85F; --oro-claro:#F2DD93; --bronce:#9C7B3E;
    --cian:#5EE6E0; --cian-claro:#A8F2EE; --tier1:#F2DD93; --tier2:#C7CEDB;
    --tier3:#86B5A6; --radio:14px;
  }
  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    margin:0; font-family:'Inter',system-ui,sans-serif; color:var(--marfil);
    background:var(--obsidiana); -webkit-font-smoothing:antialiased; line-height:1.6;
  }
  .cielo{ position:fixed; inset:0; z-index:-1;
    background:
      radial-gradient(1100px 620px at 50% -8%, rgba(94,230,224,.10), transparent 60%),
      radial-gradient(820px 520px at 82% 6%, rgba(217,184,95,.08), transparent 55%),
      linear-gradient(180deg,#080B14, #0B1020 42%, #070A12);
  }
  .estrellas{ position:fixed; inset:0; z-index:-1; opacity:.55;
    background-image:
      radial-gradient(1.4px 1.4px at 24px 36px, rgba(255,255,255,.55), transparent),
      radial-gradient(1.2px 1.2px at 130px 90px, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 200px 160px, rgba(94,230,224,.45), transparent),
      radial-gradient(1.3px 1.3px at 300px 40px, rgba(255,255,255,.40), transparent);
    background-size:420px 320px; background-repeat:repeat;
  }
  .lienzo-central{ max-width:1080px; margin:0 auto; padding:0 32px; }

  /* Barra */
  header.barra{ position:sticky; top:0; z-index:10;
    background:linear-gradient(180deg, rgba(8,11,20,.92), rgba(8,11,20,.55));
    backdrop-filter:blur(8px); border-bottom:1px solid rgba(217,184,95,.16); }
  .barra .fila{ display:flex; align-items:center; justify-content:space-between; padding:16px 0; }
  .marca{ font-family:'Cinzel',serif; font-weight:600; font-size:1.5rem; letter-spacing:.26em;
    background:linear-gradient(180deg,#F2DD93,#D9B85F 55%,#9C7B3E);
    -webkit-background-clip:text; background-clip:text; color:transparent; }
  .marca-sub{ display:block; font-family:'Cormorant Garamond',serif; font-style:italic;
    font-size:.82rem; letter-spacing:.1em; color:var(--marfil-2); }
  nav.dash-nav{ display:flex; gap:28px; align-items:center; }
  nav.dash-nav a{ color:var(--marfil-2); text-decoration:none; font-size:.8rem;
    letter-spacing:.14em; text-transform:uppercase; transition:color .2s; }
  nav.dash-nav a:hover{ color:var(--oro-claro); }

  /* Hero */
  .hero{ padding:48px 0 32px; text-align:center; }
  .hero h1{ font-family:'Cinzel',serif; font-weight:500; font-size:clamp(1.8rem,3.5vw,2.4rem);
    margin:0 0 8px; color:var(--marfil); letter-spacing:.16em; }
  .hero p{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--marfil-2);
    margin:0 0 6px; font-size:1.05rem; }

  /* Cards de resumen */
  .resumen-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:18px; margin:28px 0 42px; }
  .resumen-grid.x-visible{ grid-template-columns:repeat(5,1fr); }
  .resumen-card{ background:var(--panel); border:1px solid var(--panel-borde);
    border-radius:var(--radio); padding:22px 20px; text-align:center;
    backdrop-filter:blur(6px); transition:.25s; }
  .resumen-card:hover{ border-color:rgba(242,221,147,.5); transform:translateY(-2px); }
  .resumen-card .valor{
    font-family:'Cinzel',serif; font-weight:500; font-size:clamp(1.6rem,3vw,2.2rem);
    letter-spacing:.06em; margin:0 0 6px;
    background:linear-gradient(180deg,#F2DD93,#D9B85F);
    -webkit-background-clip:text; background-clip:text; color:transparent; }
  .resumen-card .label{ font-size:.76rem; letter-spacing:.08em; color:var(--tenue);
    text-transform:uppercase; }

  /* Barras de tokens */
  .token-barras{ margin:36px 0; }
  .token-barras h2{ font-family:'Cinzel',serif; font-weight:500; letter-spacing:.14em;
    font-size:1.15rem; color:var(--marfil); margin:0 0 20px; }
  .barra-row{ display:flex; align-items:center; gap:14px; margin-bottom:10px; font-size:.8rem; }
  .barra-row .run-id{ width:130px; flex:none; color:var(--tenue); font-family:'Inter',sans-serif;
    letter-spacing:.04em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .barra-row .barra-track{ flex:1; height:22px; background:rgba(20,27,46,.6);
    border-radius:6px; overflow:hidden; }
  .barra-row .barra-fill{ height:100%; border-radius:6px;
    background:linear-gradient(90deg, rgba(94,230,224,.65), rgba(217,184,95,.5)); }
  .barra-row .barra-val{ width:80px; flex:none; text-align:right; color:var(--marfil-2);
    font-variant-numeric:tabular-nums; }
  .barra-row.dim{ opacity:.3; }

  /* Tabla de historial */
  .historial h2{ font-family:'Cinzel',serif; font-weight:500; letter-spacing:.14em;
    font-size:1.15rem; color:var(--marfil); margin:44px 0 20px; }

  /* Grupos por día */
  .day-group{ margin-bottom:24px; }
  .day-header{ display:flex; align-items:center; gap:14px; padding:10px 14px;
    background:var(--panel); border:1px solid var(--panel-borde); border-radius:var(--radio);
    cursor:pointer; user-select:none; transition:.2s; margin-bottom:4px; }
  .day-header:hover{ border-color:rgba(242,221,147,.4); }
  .day-header .day-label{ font-family:'Cinzel',serif; font-weight:500; letter-spacing:.12em;
    font-size:.95rem; color:var(--marfil); flex:1; }
  .day-header .day-stats{ display:flex; gap:24px; font-size:.78rem; color:var(--marfil-2);
    font-variant-numeric:tabular-nums; }
  .day-header .day-arrow{ color:var(--oro); font-size:1.2rem; transition:transform .25s;
    width:20px; text-align:center; }
  .day-group.collapsed .day-arrow{ transform:rotate(-90deg); }
  .day-group.collapsed .day-body{ display:none; }
  .day-body{ border:1px solid rgba(217,184,95,.08); border-top:0; border-radius:0 0 var(--radio) var(--radio);
    overflow:hidden; }

  /* Tabla */
  table{ width:100%; border-collapse:collapse; font-size:.82rem; }
  thead th{ text-align:left; font-weight:500; font-size:.72rem; letter-spacing:.1em;
    text-transform:uppercase; color:var(--tenue); padding:8px 12px 10px;
    border-bottom:1px solid rgba(217,184,95,.16); background:rgba(13,19,34,.5); }
  tbody td{ padding:10px 12px; border-bottom:1px solid rgba(217,184,95,.06);
    color:var(--marfil-2); white-space:nowrap; }
  tbody tr.main-row{ cursor:pointer; transition:background .15s; }
  tbody tr.main-row:hover{ background:rgba(217,184,95,.05); }
  tbody tr.main-row:nth-child(4n+1),
  tbody tr.main-row:nth-child(4n+2){ background:rgba(94,230,224,.018); }
  tbody tr.main-row:nth-child(4n+1):hover,
  tbody tr.main-row:nth-child(4n+2):hover{ background:rgba(217,184,95,.06); }
  tbody tr.main-row.expanded{ background:rgba(94,230,224,.06); }
  .tokens-cell{ color:var(--cian-claro); font-variant-numeric:tabular-nums; }
  .cost-cell{ color:var(--oro-claro); font-variant-numeric:tabular-nums; }
  .duration-cell{ color:var(--tenue); font-variant-numeric:tabular-nums; }

  /* Fila de detalle */
  tr.detail-row{ display:none; }
  tr.detail-row.visible{ display:table-row; }
  tr.detail-row td{ padding:0; border-bottom:1px solid rgba(217,184,95,.12); }
  .detail-inner{ padding:14px 24px 18px; display:flex; gap:32px; flex-wrap:wrap; }
  .detail-section{ min-width:220px; flex:1; }
  .detail-section h4{ font-family:'Cinzel',serif; font-size:.7rem; letter-spacing:.1em;
    color:var(--tenue); margin:0 0 10px; text-transform:uppercase; }
  .detail-section table{ font-size:.76rem; margin:0; }
  .detail-section thead th{ font-size:.68rem; padding:0 14px 6px; background:transparent; }
  .detail-section tbody td{ padding:5px 14px; border:0; }
  .x-detail{ display:flex; gap:20px; font-size:.78rem; color:var(--marfil-2); }
  .x-detail .x-label{ color:var(--tenue); }
  .x-detail .x-val{ color:var(--oro-claro); font-variant-numeric:tabular-nums; }

  /* Badges */
  .badges{ display:flex; gap:5px; flex-wrap:nowrap; }
  .badge{ display:inline-block; padding:2px 8px; border-radius:10px; font-size:.66rem;
    letter-spacing:.08em; text-transform:uppercase; white-space:nowrap; }
  .badge-ia{ background:rgba(94,230,224,.12); color:var(--cian-claro);
    border:1px solid rgba(94,230,224,.3); }
  .badge-det{ background:rgba(142,137,121,.12); color:var(--tenue);
    border:1px solid rgba(142,137,121,.3); }
  .badge-tl{ background:rgba(242,221,147,.1); color:var(--oro-claro);
    border:1px solid rgba(242,221,147,.25); }
  .badge-x{ background:rgba(134,181,166,.12); color:var(--tier3);
    border:1px solid rgba(134,181,166,.3); }

  /* Vacío */
  .vacio{ text-align:center; padding:60px 0; color:var(--tenue); }
  .vacio p{ font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; }

  /* Footer */
  footer{ margin-top:64px; border-top:1px solid rgba(217,184,95,.16);
    background:linear-gradient(180deg, transparent, rgba(94,230,224,.03)); }
  .pie{ padding:40px 0 50px; text-align:center; }
  .pie .marca{ font-size:1.1rem; }
  .pie .lema{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--tenue);
    font-size:.95rem; margin:16px 0 0; }

  /* Responsive */
  @media (max-width:860px){
    .resumen-grid{ grid-template-columns:repeat(2,1fr); }
    .resumen-grid.x-visible{ grid-template-columns:repeat(3,1fr); }
  }
  @media (max-width:480px){
    .lienzo-central{ padding:0 16px; }
    .resumen-grid{ grid-template-columns:1fr 1fr; gap:10px; }
    .resumen-grid.x-visible{ grid-template-columns:1fr 1fr; }
    .resumen-card{ padding:16px 12px; }
    .resumen-card .valor{ font-size:1.3rem; }
    .barra-row .run-id{ width:100px; font-size:.7rem; }
    .barra-row .barra-val{ width:60px; font-size:.7rem; }
    table{ font-size:.72rem; }
    thead th, tbody td{ padding:8px 8px; }
    .hero{ padding:32px 0 20px; }
    .hero h1{ font-size:1.4rem; }
    .day-header{ flex-wrap:wrap; }
    .day-header .day-stats{ gap:12px; }
  }
</style>
</head>
<body>
<div class="cielo" aria-hidden="true"></div>
<div class="estrellas" aria-hidden="true"></div>

<header class="barra">
  <div class="lienzo-central fila">
    <div>
      <span class="marca">SIBYLLA</span>
      <span class="marca-sub">dashboard · métricas</span>
    </div>
    <nav class="dash-nav">
      <a href="index.html">← sitio</a>
    </nav>
  </div>
</header>

<!-- ---- Contenido del dashboard ---- -->
<main class="lienzo-central">

  <section class="hero">
    <h1>Dashboard</h1>
    <p>Historial de regeneraciones y consumo de tokens</p>
  </section>

  {% if runs %}
  <!-- ---- Resumen ---- -->
  <div class="resumen-grid{% if summary.has_x %} x-visible{% endif %}">
    <div class="resumen-card">
      <div class="valor">{{ summary.runs_n }}</div>
      <div class="label">Ejecuciones</div>
    </div>
    <div class="resumen-card">
      <div class="valor">{{ "{:,}".format(summary.tokens_total) }}</div>
      <div class="label">Tokens totales</div>
    </div>
    <div class="resumen-card">
      <div class="valor">{{ summary.items_total }}</div>
      <div class="label">Ítems procesados</div>
    </div>
    {% if summary.has_x %}
    <div class="resumen-card">
      <div class="valor">${{ "%.3f"|format(summary.x_cost) }}</div>
      <div class="label">Costo X ({{ summary.x_reads_total }} posts)</div>
    </div>
    {% endif %}
    <div class="resumen-card">
      <div class="valor">${{ "%.2f"|format(summary.cost_total) }}</div>
      <div class="label">Costo total</div>
    </div>
  </div>

  <!-- ---- Barras de tokens por ejecución ---- -->
  <section class="token-barras">
    <h2>Tokens por ejecución</h2>
    {% for r in runs %}
    {% if r.tokens_total > 0 %}
    {% set pct = (r.tokens_total / max_token * 100) if max_token else 0 %}
    <div class="barra-row">
      <span class="run-id" title="{{ r.ts }}">{{ r.run_id }}</span>
      <div class="barra-track">
        <div class="barra-fill" style="width:{{ "%.1f"|format(pct) }}%"></div>
      </div>
      <span class="barra-val">{{ "{:,}".format(r.tokens_total) }}</span>
    </div>
    {% endif %}
    {% endfor %}
    {% if summary.runs_with_llm == 0 %}
    <div class="barra-row dim">
      <span class="run-id">—</span>
      <div class="barra-track"></div>
      <span class="barra-val">sin datos</span>
    </div>
    {% endif %}
  </section>

  <!-- ---- Tabla de historial (agrupado por día) ---- -->
  <section class="historial">
    <h2>Historial</h2>

    {% for day in days %}
    <div class="day-group" id="day-{{ loop.index }}">
      <div class="day-header" onclick="this.parentElement.classList.toggle('collapsed')">
        <span class="day-arrow">▼</span>
        <span class="day-label">{{ day.label }}</span>
        <span class="day-stats">
          <span>{{ day.runs_n }} ejec.</span>
          {% if day.tokens_day > 0 %}
          <span>{{ "{:,}".format(day.tokens_day) }} tok.</span>
          {% endif %}
          {% if day.cost_day > 0 %}
          <span>${{ "%.4f"|format(day.cost_day) }}</span>
          {% endif %}
        </span>
      </div>
      <div class="day-body">
      <table>
        <thead>
          <tr>
            <th></th>
            <th>Hora</th>
            <th>Temas</th>
            <th>Ítems</th>
            <th>Tokens</th>
            <th>Costo</th>
            <th>Dur.</th>
            <th>Flags</th>
          </tr>
        </thead>
        <tbody>
          {% for r in day.runs %}
          {% set detail_id = "det-" ~ day.label ~ "-" ~ loop.index %}
          <tr class="main-row" data-detail="{{ detail_id }}" onclick="toggleDetail('{{ detail_id }}', this)">
            <td style="width:28px; color:var(--tenue); font-size:.7rem; text-align:right; padding-right:4px;">
              {{ loop.index }}
            </td>
            <td style="color:var(--marfil);">{{ r.ts.split(",")[1].strip() if "," in r.ts else r.ts }}</td>
            <td>{{ r.topics }}</td>
            <td>{{ r.items_final }}</td>
            <td class="tokens-cell">{% if r.tokens_total > 0 %}{{ "{:,}".format(r.tokens_total) }}{% else %}—{% endif %}</td>
            <td class="cost-cell">{% if r.cost > 0 %}${{ "%.4f"|format(r.cost) }}{% else %}—{% endif %}</td>
            <td class="duration-cell">{{ "%.1f"|format(r.duration_s) }}s</td>
            <td>
              <span class="badges">
                {% if r.mode == "IA" %}
                <span class="badge badge-ia">IA</span>
                {% else %}
                <span class="badge badge-det">DET</span>
                {% endif %}
                {% if r.translate %}
                <span class="badge badge-tl" title="Traducido">🌐</span>
                {% endif %}
                {% if r.has_x %}
                <span class="badge badge-x" title="{{ r.x_reads }} posts X">X{{ r.x_reads }}</span>
                {% endif %}
              </span>
            </td>
          </tr>
          <tr class="detail-row" id="{{ detail_id }}">
            <td></td>
            <td colspan="7">
            <div class="detail-inner">
              {% if r.has_x %}
              <div class="detail-section">
                <h4>X / Twitter</h4>
                <div class="x-detail">
                  <span><span class="x-label">Posts leídos:</span> <span class="x-val">{{ r.x_reads }}</span></span>
                  <span><span class="x-label">Costo:</span> <span class="x-val">${{ "%.5f"|format(r.x_cost) }}</span></span>
                </div>
              </div>
              {% endif %}
              {% if r.calls %}
              <div class="detail-section">
                <h4>Llamadas LLM</h4>
                <table>
                  <thead><tr><th>Propósito</th><th>Modelo</th><th>Input</th><th>Output</th><th>Total</th><th>Costo</th></tr></thead>
                  <tbody>
                  {% for c in r.calls %}
                  <tr>
                    <td>{{ c.purpose }}</td>
                    <td style="font-size:.7rem;">{{ c.model_short }}</td>
                    <td class="tokens-cell">{{ "{:,}".format(c.input) }}</td>
                    <td class="tokens-cell">{{ "{:,}".format(c.output) }}</td>
                    <td class="tokens-cell">{{ "{:,}".format(c.total) }}</td>
                    <td class="cost-cell">{% if c.cost is not none %}${{ "%.5f"|format(c.cost) }}{% else %}—{% endif %}</td>
                  </tr>
                  {% endfor %}
                  </tbody>
                </table>
              </div>
              {% endif %}
              {% if not r.has_x and not r.calls %}
              <div class="detail-section">
                <p style="color:var(--tenue); font-size:.8rem;">Sin llamadas externas en esta ejecución.</p>
              </div>
              {% endif %}
            </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
    </div>
    {% endfor %}

  </section>

  {% else %}
  <!-- Sin datos -->
  <div class="vacio">
    <p>Sin ejecuciones registradas todavía.</p>
    <p>Ejecuta el pipeline con <code>--html</code> para empezar a registrar métricas.</p>
  </div>
  {% endif %}

</main>

<footer>
  <div class="lienzo-central pie">
    <span class="marca">SIBYLLA</span>
    <p class="lema">Dashboard generado {{ generado }}</p>
  </div>
</footer>

<script>
/* Toggle de fila de detalle: click en cualquier fila principal expande/colapsa su detalle. */
function toggleDetail(id, row){
  var detail=document.getElementById(id);
  if(!detail) return;
  var visible=detail.classList.contains('visible');
  // Cerrar todas las demás
  var allDetails=document.querySelectorAll('tr.detail-row.visible');
  var allRows=document.querySelectorAll('tr.main-row.expanded');
  allDetails.forEach(function(d){ d.classList.remove('visible'); });
  allRows.forEach(function(r){ r.classList.remove('expanded'); });
  // Abrir esta si no estaba abierta
  if(!visible){
    detail.classList.add('visible');
    row.classList.add('expanded');
  }
}

/* Colapsar todos los grupos de día por defecto (excepto el más reciente). */
(function(){
  var groups=document.querySelectorAll('.day-group');
  groups.forEach(function(g, i){
    if(i > 0) g.classList.add('collapsed');
  });
})();
</script>
</body>
</html>
